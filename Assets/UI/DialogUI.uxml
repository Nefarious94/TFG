<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="DialogContainer" style="flex-grow: 1; bottom: 0; position: absolute; align-self: auto; height: 30%; width: 100%; border-left-color: rgb(100, 0, 0); border-right-color: rgb(100, 0, 0); border-top-color: rgb(100, 0, 0); border-bottom-color: rgb(100, 0, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; background-color: rgb(0, 0, 0); font-size: 32px; color: rgb(255, 255, 255);">
        <ui:Label text="" name="DialogLabel" style="font-size: 32px;"/>
    </ui:VisualElement>
    <ui:VisualElement name="DialogOptions" style="flex-grow: 1; right: 0; width: auto; height: auto; position: absolute; bottom: 30.1%; top: auto; left: auto; align-items: auto; justify-content: flex-start; -unity-text-align: upper-left; min-width: 0%; min-height: auto; max-width: 40%; max-height: none; font-size: 32px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(100, 0, 0); border-right-color: rgb(100, 0, 0); border-top-color: rgb(100, 0, 0); border-bottom-color: rgb(100, 0, 0); background-color: rgb(0, 0, 0); color: rgb(255, 255, 255);">
        <ui:ListView name="DialogList" fixed-item-height="40" virtualization-method="DynamicHeight" style="min-height: auto; max-height: none; width: auto; max-width: none; height: auto;"/>
    </ui:VisualElement>
</ui:UXML>
