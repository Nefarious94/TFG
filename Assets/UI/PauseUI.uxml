<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="PauseContainer" style="flex-grow: 1; background-color: rgb(0, 0, 0); border-left-color: rgb(100, 0, 0); border-right-color: rgb(100, 0, 0); border-top-color: rgb(100, 0, 0); border-bottom-color: rgb(100, 0, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; top: 50px; left: 50px; width: 400px; height: 500px; position: absolute;">
        <ui:ListView name="PauseList" fixed-item-height="40" virtualization-method="DynamicHeight" style="font-size: 32px; color: rgb(255, 255, 255);"/>
    </ui:VisualElement>
</ui:UXML>
