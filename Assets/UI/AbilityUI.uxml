<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="AbilityContainer" enabled="true" style="flex-grow: 1; width: 400px; height: 500px; background-color: rgb(0, 0, 0); font-size: 32px; position: absolute; top: 50px; left: 50px;">
        <ui:ListView name="AbilityList" tabindex="0" enabled="true" fixed-item-height="40" show-add-remove-footer="false" horizontal-scrolling="false" style="height: 420px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 2px; border-top-right-radius: 2px; border-bottom-right-radius: 2px; border-bottom-left-radius: 2px; border-left-color: rgb(130, 0, 0); border-right-color: rgb(130, 0, 0); border-top-color: rgb(130, 0, 0); border-bottom-color: rgb(130, 0, 0); color: rgb(255, 255, 255);"/>
        <ui:VisualElement name="DescriptionBox" style="flex-grow: 1; width: 400px; height: 80px; position: absolute; bottom: 0; border-left-color: rgb(111, 0, 0); border-right-color: rgb(111, 0, 0); border-top-color: rgb(111, 0, 0); border-bottom-color: rgb(111, 0, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px;">
            <ui:Label text="" name="DescriptionLabel" parse-escape-sequences="false" style="height: 80px; color: rgb(255, 255, 255); bottom: auto; position: absolute; width: 400px; left: 0; font-size: 32px; top: 2px;"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
